---
interface Props {
  value?: string;
  name?: string;
  required?: boolean;
  t: (key: string) => string;
  disabledCategories?: string[];
}

const { value = "", name = "raceCategory", required = true, t, disabledCategories = [] } = Astro.props;
---

<select
  name={name}
  required={required}
  class="mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500"
>
  <option value="">{t("wilczypolmaraton.form.select_category")}</option>
  <option value="21km" selected={value === "21km"} disabled={disabledCategories.includes("21km")}>Półmaraton 21km</option>
  <option value="10km" selected={value === "10km"} disabled={disabledCategories.includes("10km")}>Bieg 10km</option>
</select>
