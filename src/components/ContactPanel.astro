---
// Reusable "contact the organizer" panel with a clickable email (and phone)
// link. Used on the Nocny Zew Wilka pages and the Wilczy Półmaraton panel.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class={`rounded-xl border-2 border-emerald-200 bg-emerald-50 p-6 ${className}`}>
  <div class="flex items-start gap-3">
    <svg class="h-6 w-6 shrink-0 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
    </svg>
    <div>
      <h3 class="text-lg font-bold text-slate-900">Masz pytania?</h3>
      <p class="mt-1 text-sm text-slate-700">
        Skontaktuj się z organizatorem — napisz na
        <a href="mailto:biuro@zatyrani.pl" class="font-semibold text-emerald-700 underline underline-offset-2 hover:text-emerald-800">biuro@zatyrani.pl</a>
        lub zadzwoń
        <a href="tel:784640977" class="font-semibold text-emerald-700 hover:text-emerald-800">784 640 977</a>.
      </p>
    </div>
  </div>
</div>
