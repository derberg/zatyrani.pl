---
import NewsCard from "../NewsCard.astro";
import SubscribeForm from "../SubscribeForm.astro";
import TrainingCard from "../TrainingCard.astro";
import { news } from "../../data/news";
import { trainings } from "../../data/trainings";

interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

// Parse "DD/MM/YYYY HH:mm" and return timestamp (ms since 1970)
function toTimestamp(datetime: string): number {
  const [date, time] = datetime.split(" ");
  const [day, month, year] = date.split("/").map(Number);
  const [hour, minute] = time.split(":").map(Number);
  return new Date(year, month - 1, day, hour, minute).getTime();
}

const nowMs = Date.now();

const upcomingTrainings = trainings
  .filter((training) => toTimestamp(training.datetime) >= nowMs)
  .sort((a, b) => toTimestamp(a.datetime) - toTimestamp(b.datetime));

---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="text-center mb-12">
    <img src="/zatyrani_logo.webp" alt="Zatyrani" class="mx-auto h-32" />
  </div>

  {/* Only show upcoming trainings if any future items exist */}
  {
    upcomingTrainings.length > 0 && (
      <section class="mb-12">
        <h2 class="text-3xl font-bold mb-4">{t("home.upcoming_trainings")}</h2>
        <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
          {upcomingTrainings.slice(0, 6).map((training) => (
            <TrainingCard {...training} t={t} />
          ))}
        </div>
      </section>
    )
  }

  <section id="niebocross-rekonesans-banner" class="mb-12">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-sky-900 via-slate-900 to-emerald-900 text-white shadow-xl">
      <div class="absolute inset-0 opacity-60">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_50%,rgba(94,234,212,0.15),transparent_50%)]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_20%,rgba(56,189,248,0.12),transparent_40%)]"></div>
      </div>
      <div class="relative px-8 py-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">

          <!-- Col 1: Title + link + logos below -->
          <div class="flex flex-col gap-4">
            <h2 class="text-xl font-bold text-white leading-snug">
              {t("niebocross.official_trainings_title_prefix")} <a href="https://klinika-nieborowice.pl/" target="_blank" rel="noopener noreferrer" class="text-emerald-300 hover:text-white underline transition">Kliniki Nieborowice</a>
            </h2>
            <a href="/niebocross#treningi-rekonesansowe" class="text-sm font-semibold text-emerald-400 hover:text-white transition self-start">
              {t("niebocross.official_trainings_link")} →
            </a>
            <div class="flex flex-row items-center gap-4 mt-2">
              <div class="rounded-2xl bg-white p-3 flex-none">
                <img src="/niebocross_logo.svg" alt="NieboCross" class="h-14 w-auto object-contain" loading="lazy" />
              </div>
              <a href="https://klinika-nieborowice.pl/" target="_blank" rel="noopener noreferrer" class="rounded-2xl bg-white p-3 flex-none block">
                <img src="/niebocross/klinika.webp" alt="Klinika Nieborowice" class="h-14 w-auto object-contain" loading="lazy" />
              </a>
            </div>
          </div>

          <!-- Col 2: Date chips (far right) -->
          <div class="flex flex-row gap-3 flex-wrap">
            <div class="rounded-xl bg-white/10 ring-1 ring-white/15 px-5 py-3 text-center">
              <p class="text-4xl font-bold text-white">26 marca</p>
              <p class="text-xs text-emerald-300 mt-0.5">czw · 19:00</p>
            </div>
          </div>

        </div>
      </div>
    </div>
    <script is:inline>
      const deadline = new Date('2026-03-26T19:00:00Z').getTime();
      if (Date.now() > deadline) {
        const el = document.getElementById('niebocross-rekonesans-banner');
        if (el) el.remove();
      }
    </script>
  </section>

  <!-- Aktualności -->
  <section>
    <h1 class="text-3xl font-bold mb-2">{t("news.title")}</h1>
    <p class="text-gray-600 mb-8">{t("news.description")}</p>

    <div class="grid gap-8 md:grid-cols-1 lg:grid-cols-2">
      {
        news
          .filter((post) => post.message)
          .slice(0, 2)
          .map((post) => <NewsCard {...post} />)
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href="/aktualnosci"
        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700"
      >
        {t("home.more_news")}
      </a>
    </div>
  </section>

  <SubscribeForm t={t} />
</div>

<div id="auth-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
  <div class="bg-white p-6 rounded-lg shadow-lg max-w-md w-full mx-4 text-center">
    <h2 class="text-xl font-bold mb-4">{t("home.no_permissions_title")}</h2>
    <p class="mb-4">{t("home.no_permissions_message")}</p>
    <button id="modal-close" class="bg-purple-600 hover:bg-purple-700 text-white py-2 px-4 rounded">
      {t("home.ok")}
    </button>
  </div>
</div>

<script>
  // Check for access_denied param and show modal
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('access_denied')) {
    const modal = document.getElementById('auth-modal');
    const closeBtn = document.getElementById('modal-close');
    modal.classList.remove('hidden');
    closeBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
      // Remove param from URL
      const newUrl = window.location.pathname;
      window.history.replaceState({}, document.title, newUrl);
    });
  }
</script>
