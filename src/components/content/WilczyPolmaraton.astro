---
import PhotoGallery from "../PhotoGallery.astro";
import { marathonPhotos2025 } from "../../data/marathon-photos";

interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;

const eventDate = "17.10.2026";
const eventNumber = "IV";
const ytPreviewLink = "https://www.youtube.com/embed/sY6au0yZyp4";
---

<!-- Hero Section -->
<div class="relative h-[60vh] flex items-center justify-center text-white">
  <div class="absolute inset-0">
    <img
      src="/halfmarathon/header.webp"
      alt={t("halfmarathon.background_alt")}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>
  <div class="relative text-center space-y-4">
    <div class="bg-white/20 px-8 py-4 rounded-lg shadow-lg backdrop-blur-sm mx-auto max-w-full">
      <h1 class="text-5xl font-bold text-white">
        {eventNumber} {t("halfmarathon.event_name")}
      </h1>
    </div>

    <div class="bg-white/20 px-8 py-4 rounded-lg shadow-lg backdrop-blur-sm mx-auto inline-block">
      <h1 class="text-3xl font-bold text-white">{eventDate}</h1>
    </div>

    <div class="flex flex-wrap justify-center gap-3 text-lg">
      <span class="bg-white/20 px-4 py-2 rounded-full backdrop-blur-sm">🏃 22km bieg</span>
      <span class="bg-white/20 px-4 py-2 rounded-full backdrop-blur-sm">🐕 22km canicross</span>
      <span class="bg-white/20 px-4 py-2 rounded-full backdrop-blur-sm">🥢 11km nordic walking</span>
    </div>

    <div id="registration-buttons-wrapper" class="flex flex-wrap justify-center gap-3">
      <div id="registration-buttons" class="contents">
        <a
          href="/wilczy-polmaraton/rejestracja"
          class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full"
        >
          {t("halfmarathon.register_button")}
        </a>
        <a
          href="/wilczy-polmaraton/zaloguj"
          class="inline-block bg-white/20 hover:bg-white/30 text-white px-8 py-3 rounded-full backdrop-blur-sm border border-white/40"
        >
          {t("halfmarathon.login_button")}
        </a>
        <a
          href="/wilczy-polmaraton/lista"
          class="inline-block bg-white/20 hover:bg-white/30 text-white px-8 py-3 rounded-full backdrop-blur-sm"
        >
          {t("halfmarathon.participants_list_button")}
        </a>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <!-- Event Details -->
  <div class="grid md:grid-cols-2 gap-12 mb-16">
    <!-- Video Section -->
    <div>
      <div class="aspect-video rounded-lg overflow-hidden">
        <iframe
          width="100%"
          height="100%"
          src={ytPreviewLink}
          title={t("halfmarathon.title")}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>
      </div>
    </div>

    <!-- Text Section -->
    <div class="flex items-center">
      <div class="space-y-6 text-xl">
        <p class="text-gray-700">
          {t("halfmarathon.paragraph1")}
        </p>
        <p class="text-gray-700">
          {t("halfmarathon.paragraph2")}
        </p>
        <p class="text-gray-700">
          {t("halfmarathon.paragraph3")}
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Partners Section -->
<section id="partnerzy" class="mx-auto max-w-6xl px-6 py-4 mb-16">
  <div class="mb-8 text-center">
    <h2 class="text-3xl font-bold text-slate-900">{t("halfmarathon.partners_title")}</h2>
    <p class="mt-3 text-lg text-slate-700">
      {t("halfmarathon.partners_thanks")}
    </p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md flex flex-col items-center justify-center">
      <a
        href="https://wkdzik.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block"
      >
        <img
          src="/halfmarathon/dzik.svg"
          alt="DZIK"
          class="h-24 w-auto object-contain mb-3"
        />
      </a>
      <h3 class="text-lg font-bold text-slate-900 text-center">
        {t("halfmarathon.dzik_name")}
      </h3>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md flex flex-col items-center justify-center">
      <a
        href="https://pilchowice.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block"
      >
        <img
          src="/halfmarathon/gmina-pilchowice.png"
          alt="Gmina Pilchowice"
          class="h-24 w-auto object-contain mb-3"
        />
      </a>
      <h3 class="text-lg font-bold text-slate-900 text-center">
        {t("halfmarathon.gmina_pilchowice_name")}
      </h3>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md flex flex-col items-center justify-center">
      <a
        href="https://gratisownia.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="block"
      >
        <img
          src="/gratisownia.png"
          alt="Gratisownia.pl"
          class="h-24 w-auto object-contain mb-3"
        />
      </a>
      <h3 class="text-lg font-bold text-slate-900 text-center">
        {t("halfmarathon.gratisownia_name")}
        <a
          href="https://www.youtube.com/@gratisownia"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block ml-2 text-red-600 hover:text-red-700 transition"
          title="YouTube Gratisownia"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </h3>
      <p class="text-sm text-slate-600 text-center mt-2">{t("halfmarathon.gratisownia_desc")}</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md flex flex-col items-center justify-center">
      <a
        href="https://gok.pilchowice.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block"
      >
        <img
          src="/niebocross/gok.png"
          alt="Gminny Ośrodek Kultury w Pilchowicach"
          class="h-24 w-auto object-contain mb-3"
        />
      </a>
      <h3 class="text-lg font-bold text-slate-900 text-center">
        {t("halfmarathon.gok_name")}
      </h3>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md flex flex-col items-center justify-center">
      <a
        href="https://radio.katowice.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block"
      >
        <img
          src="/halfmarathon/radiokatowice.jpeg"
          alt="Radio Katowice"
          class="h-24 w-auto object-contain mb-3"
        />
      </a>
      <h3 class="text-lg font-bold text-slate-900 text-center">
        {t("halfmarathon.radiokatowice_name")}
      </h3>
    </div>

    <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5 shadow-md flex flex-col items-center justify-center min-h-[12rem]">
      <p class="text-sm font-semibold text-slate-600 text-center">
        {t("halfmarathon.partner_support")}{" "}
        <a class="text-emerald-700 hover:text-emerald-800 underline" href="mailto:biuro@zatyrani.pl">biuro@zatyrani.pl</a>
      </p>
    </div>
  </div>
</section>

<!-- Prices Section -->
<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
  <h2 class="text-3xl font-bold text-center">{t("halfmarathon.prices_title")}</h2>
  <p class="text-center text-gray-600 mt-2">{t("halfmarathon.prices_intro")}</p>

  <ul class="mt-8 space-y-4 text-gray-700 text-lg">
    <li class="flex items-start">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-green-500 mr-2 mt-1.5 flex-none"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
      </svg>
      <span>
        <span class="font-semibold">{t("halfmarathon.price_run_label")}</span> — {t("halfmarathon.price_run_value")}
      </span>
    </li>
    <li class="flex items-start">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-green-500 mr-2 mt-1.5 flex-none"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
      </svg>
      <span>
        <span class="font-semibold">{t("halfmarathon.price_nw_label")}</span> — {t("halfmarathon.price_nw_value")}
      </span>
    </li>
    <li class="flex items-start">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-green-500 mr-2 mt-1.5 flex-none"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
      </svg>
      <span class="flex items-center gap-3">
        <img
          src="/halfmarathon/2026/koszulka.jpeg"
          alt={t("halfmarathon.price_tshirt_label")}
          class="w-16 h-16 rounded-md object-cover shrink-0"
          loading="lazy"
        />
        <span>
          <span class="font-semibold">{t("halfmarathon.price_tshirt_label")}</span> — {t("halfmarathon.price_tshirt_value")}
        </span>
      </span>
    </li>
  </ul>

  <p class="mt-6 text-center text-gray-600">
    {t("halfmarathon.prices_note")}
  </p>
</section>

<!-- Facebook News -->
<section class="mt-16 mb-16">
  <h2 class="text-3xl font-bold text-center">{t("halfmarathon.fb_news_title")}</h2>
  <div class="max-w-2xl mx-auto mt-4 text-center">
    <p class="text-gray-700 text-lg">{t("halfmarathon.fb_news_description")}</p>
    <a
      href="https://www.facebook.com/events/1557925925215210"
      target="_blank"
      class="inline-block mt-4 bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-full"
    >
      {t("halfmarathon.fb_news_link")}
    </a>
  </div>
</section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <!-- Bullet List and Image Section -->
  <h2 class="text-3xl font-bold text-center">{t("halfmarathon.attractions_title")}</h2>
  <div class="grid md:grid-cols-2 gap-12 mb-16 py-8">
    <!-- Bullet List Section -->
    <div class="space-y-4 flex flex-col justify-center text-gray-700 text-lg">
      <ul class="list-none space-y-3">
        <li class="flex items-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-green-500 mr-2 flex-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
          </svg>
          {t("halfmarathon.attraction1")}
        </li>
        <li class="flex items-center text-gray-700">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-green-500 mr-2 flex-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
          </svg>
          {t("halfmarathon.attraction2")}
        </li>
        <li class="flex items-center text-gray-700">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-green-500 mr-2 flex-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
          </svg>
          {t("halfmarathon.attraction3")}
        </li>
        <li class="flex items-center text-gray-700">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-green-500 mr-2 flex-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
          </svg>
          {t("halfmarathon.attraction4")}
        </li>
        <li class="flex items-center text-gray-700">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-green-500 mr-2 flex-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
          </svg>
          {t("halfmarathon.attraction5")}
        </li>
      </ul>
    </div>

    <!-- Image Section -->
    <div class="flex items-center justify-center">
      <img
        src="/halfmarathon/logo.png"
        alt={t("halfmarathon.logo_alt")}
        class="w-full max-w-sm rounded-lg shadow-lg"
      />
    </div>
  </div>
</div>

<!-- Photos Section -->
<section class="max-w-7xl mx-auto">
  <h2 class="text-3xl font-bold text-center">{t("halfmarathon.photos_title")}</h2>
  <PhotoGallery
    photos={marathonPhotos2025}
    author="Paweł Bernas"
    authorLink="https://www.instagram.com/pawelbernas.fotografia"
  />
  <div class="text-center mt-4 text-lg">
    <p>
      {t("halfmarathon.photos_full_gallery")} <a
        href="https://photos.google.com/share/AF1QipPUNi2uDta48zu80edE-TiK6R03kIAuLNt7XfEQmsiRSlGmXe0ZuYHzG89zg22zJw?key=cHZmY2kyeF91WkcydS13VmF1TTF3WnJqejdGV0Z3"
        class="text-blue-600 hover:underline">{t("halfmarathon.photos_here")}</a
      >
    </p>
  </div>
</section>

<!-- Race Office Location -->
<section class="mt-16">
  <h2 class="text-3xl font-bold text-center">{t("halfmarathon.race_office_title")}</h2>
  <div class="max-w-3xl mx-auto">
    <p class="mt-4 mb-2 text-gray-600 text-center">
      {t("halfmarathon.race_office_location")}
      <div class="aspect-[16/9] rounded-lg overflow-hidden shadow-md">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d796.6238701372778!2d18.59522346969745!3d50.188842198221465!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471137d1988015fd%3A0xa1e08547df1cdfa8!2sDom%20Kultury%20w%20Wilczy%20(biuro%20GOK%20Pilchowice)!5e1!3m2!1sen!2spl!4v1735845595802!5m2!1sen!2spl"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </p>
  </div>
</section>

<script is:inline define:vars={{
  panelLabel: t("halfmarathon.panel_button"),
  listLabel: t("halfmarathon.participants_list_button")
}}>
  const wrapper = document.getElementById('registration-buttons-wrapper');

  if (wrapper) {
    const cookies = document.cookie.split(';').map(c => c.trim());
    const authCookie = cookies.find(c => c.startsWith('wilczypolmaraton_2026_auth_status='));
    const isAuthenticated = authCookie && authCookie.split('=')[1] === 'true';

    if (isAuthenticated) {
      const registrationButtons = document.getElementById('registration-buttons');
      if (registrationButtons) {
        registrationButtons.innerHTML = `
          <a href="/wilczy-polmaraton/panel" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full">
            ${panelLabel}
          </a>
          <a href="/wilczy-polmaraton/lista" class="inline-block bg-white/20 hover:bg-white/30 text-white px-8 py-3 rounded-full backdrop-blur-sm">
            ${listLabel}
          </a>
        `;
      }
    }
  }
</script>
