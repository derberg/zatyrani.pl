---
interface Props {
  photos: {
    src: string;
    alt: string;
    featured?: boolean;
  }[];
  author?: string;
  authorLink?: string;
}

const { photos, author, authorLink } = Astro.props;
---

<div class="space-y-4">
  {
    author && (
      <p class="text-center text-gray-600">
        Autor –{" "}
        {authorLink ? (
          <a
            href={authorLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:underline"
          >
            {author}
          </a>
        ) : (
          author
        )}
      </p>
    )
  }

  <div class="lg:max-w-[56%] mx-auto grid grid-cols-2 lg:grid-cols-3 gap-4 px-2 lg:px-0">
    {
      photos.map((photo) => (
        <a href={photo.src} target="_blank" rel="noopener noreferrer" class={photo.featured ? "col-span-2 lg:col-span-3" : ""}>
          <img
            src={photo.src}
            alt={photo.alt}
            class={`w-full object-cover rounded-lg hover:shadow-md transition-shadow ${photo.featured ? "aspect-video" : "aspect-[9/16]"}`}
          />
        </a>
      ))
    }
  </div>
</div>
