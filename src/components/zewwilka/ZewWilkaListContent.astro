---
// Public list of people registered for Nocny Zew Wilka. Free event, so no
// payment status is shown — registration === confirmed.
const totalLimit = 50;
---

<div class="mx-auto max-w-3xl px-6 py-12" data-api-base="/api/events/zewwilka-2026" data-limit={totalLimit.toString()}>
  <div class="text-center">
    <h2 class="text-3xl font-bold text-slate-900">Lista zapisanych</h2>
    <p class="mt-2 text-slate-600">Wilcze stado rośnie. Oto kto już dołączył do nocnego biegu.</p>
    <div id="count" class="mt-4 inline-block rounded-full bg-emerald-100 px-5 py-2 text-lg font-bold text-emerald-800"></div>
  </div>

  <!-- Category filter -->
  <div id="filters" class="mt-8 flex flex-wrap justify-center gap-2">
    <button type="button" data-cat="" class="filter-btn rounded-full px-4 py-2 text-sm font-semibold">Wszyscy</button>
    <button type="button" data-cat="10km" class="filter-btn rounded-full px-4 py-2 text-sm font-semibold">Bieg 10 km</button>
    <button type="button" data-cat="10km_nw" class="filter-btn rounded-full px-4 py-2 text-sm font-semibold">Nordic Walking</button>
    <button type="button" data-cat="10km_canicross" class="filter-btn rounded-full px-4 py-2 text-sm font-semibold">Canicross</button>
  </div>

  <div id="loading" class="py-16 text-center text-slate-600">Ładujemy listę…</div>
  <div id="error" class="hidden py-16 text-center text-red-700"></div>
  <div id="empty" class="hidden py-16 text-center">
    <div class="text-5xl">🐺</div>
    <p class="mt-4 text-lg font-semibold text-slate-800">Nikt jeszcze się nie zapisał.</p>
    <p class="mt-1 text-slate-600">Bądź pierwszy w stadzie!</p>
    <a href="/wilczy-polmaraton/zewwilka/rejestracja" class="mt-6 inline-block rounded-full bg-emerald-600 px-6 py-3 font-semibold text-white transition hover:bg-emerald-700">Zapisz się</a>
  </div>

  <ul id="list" class="mt-6 hidden space-y-3"></ul>
</div>

<script>
  const root = document.querySelector("[data-api-base]");
  const API_BASE = root.getAttribute("data-api-base");
  const LIMIT = parseInt(root.getAttribute("data-limit"), 10);

  const CATEGORY_LABELS = {
    "10km": "Bieg 10 km",
    "10km_nw": "Nordic Walking",
    "10km_canicross": "Canicross",
  };

  const els = {
    count: document.getElementById("count"),
    loading: document.getElementById("loading"),
    error: document.getElementById("error"),
    empty: document.getElementById("empty"),
    list: document.getElementById("list"),
  };

  let all = [];
  let activeCat = "";

  const ACTIVE = ["bg-emerald-600", "text-white"];
  const IDLE = ["bg-white", "text-slate-700", "ring-1", "ring-slate-300"];

  function styleFilters() {
    document.querySelectorAll(".filter-btn").forEach((btn) => {
      const on = btn.getAttribute("data-cat") === activeCat;
      btn.classList.remove(...ACTIVE, ...IDLE);
      btn.classList.add(...(on ? ACTIVE : IDLE));
    });
  }

  function render() {
    const items = activeCat ? all.filter((p) => p.raceCategory === activeCat) : all;

    els.list.classList.toggle("hidden", items.length === 0);
    els.empty.classList.toggle("hidden", all.length !== 0);

    els.list.innerHTML = items
      .map((p, i) => {
        const cat = CATEGORY_LABELS[p.raceCategory] || p.raceCategory;
        const meta = [p.city, p.club].filter(Boolean).join(" · ");
        const polmaratonBadge = p.registeredFromSource
          ? `<span class="group relative shrink-0 cursor-help text-base leading-none" tabindex="0" aria-label="Zapisany na Wilczy Półmaraton">🐺<span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-1 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-900 px-2 py-1 text-xs font-medium text-white opacity-0 transition-opacity group-hover:opacity-100 group-focus:opacity-100">Zapisany na Wilczy Półmaraton</span></span>`
          : "";
        return `
        <li class="flex items-center justify-between gap-4 rounded-xl border border-slate-200 bg-white px-5 py-3 shadow-sm">
          <div class="flex min-w-0 items-center gap-3">
            <span class="w-6 shrink-0 text-right text-sm font-semibold text-slate-400">${i + 1}</span>
            <div class="min-w-0">
              <div class="flex items-center gap-1.5">
                <p class="truncate font-semibold text-slate-900">${p.fullName}</p>
                ${polmaratonBadge}
              </div>
              ${meta ? `<p class="truncate text-sm text-slate-500">${meta}</p>` : ""}
            </div>
          </div>
          <span class="shrink-0 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">${cat}</span>
        </li>`;
      })
      .join("");
  }

  document.querySelectorAll(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCat = btn.getAttribute("data-cat");
      styleFilters();
      render();
    });
  });

  async function init() {
    styleFilters();
    try {
      const res = await fetch(`${API_BASE}/registrations/list`);
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || "error");

      all = data.participants || [];
      els.loading.classList.add("hidden");
      els.count.textContent = `${all.length} / ${LIMIT} miejsc`;
      render();
    } catch {
      els.loading.classList.add("hidden");
      els.error.textContent = "Nie udało się pobrać listy. Odśwież stronę.";
      els.error.classList.remove("hidden");
    }
  }

  init();
</script>
