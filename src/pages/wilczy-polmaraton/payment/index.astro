---
// Static payment page that handles payment IDs dynamically
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Płatność - Wilczy Półmaraton 2026</title>
    <meta property="og:image" content="https://zatyrani.pl/wilczypolmaraton_og.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
      .container {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        text-align: center;
        max-width: 600px;
        width: 90%;
      }
      .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #667eea;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 20px auto;
      }
      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
      .error {
        color: #dc2626;
        background: #fef2f2;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
      }
      .error a {
        color: #991b1b;
        text-decoration: underline;
        font-weight: 500;
      }
      .error a:hover {
        color: #7f1d1d;
      }
      .info {
        color: #059669;
        background: #ecfdf5;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
      }
      .btn {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.75rem 1.5rem;
        background: #667eea;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
      }
      .btn:hover {
        background: #5a67d8;
      }
      #payment-form-container {
        margin-top: 1rem;
        min-height: 400px;
      }
      .amount-info {
        font-size: 1.25rem;
        color: #374151;
        margin-bottom: 1rem;
      }
      .amount-info strong {
        color: #059669;
      }
      .blik-notice {
        background: #fef3c7;
        border: 1px solid #fbbf24;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        text-align: left;
        font-size: 0.875rem;
        color: #92400e;
        line-height: 1.4;
      }
      .blik-notice strong {
        color: #78350f;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1 id="title">Przetwarzanie płatności...</h1>
      <div id="spinner" class="spinner"></div>
      <p id="message">Proszę czekać, trwa ładowanie formularza płatności.</p>
      <div id="blik-notice" class="blik-notice" style="display: none;">
        <strong>BLIK:</strong> Po wpisaniu kodu BLIK i potwierdzeniu, otwórz aplikację swojego banku i zatwierdź płatność. Bez potwierdzenia w aplikacji płatność nie zostanie zrealizowana.
      </div>
      <div id="payment-form-container" style="display: none;">
        <!-- SIBS SPG widget form will be injected here -->
      </div>
      <div id="transfer-notice" class="blik-notice" style="display: none;">
        <strong>Przelew tradycyjny:</strong> Jeśli nie możesz zapłacić BLIKIEM ani Szybkim przelewem, wykonaj przelew na konto:<br>
        <strong>42 1870 1045 2078 1084 8949 0004</strong><br>
        W tytule wpisz: <strong id="transfer-title"></strong><br>
        Po zaksięgowaniu wpłaty oznaczymy płatność ręcznie.
      </div>
      <div id="info-message" class="info" style="display: none;"></div>
      <div id="error-message" class="error" style="display: none;"></div>
      <a id="panel-link" href="/wilczy-polmaraton/panel" class="btn" style="display: none;">Przejdź do panelu</a>
    </div>

    <script>
      // Handle legacy URLs with ID in path - redirect to query parameter format
      function handleLegacyUrl() {
        const pathParts = window.location.pathname.split('/');
        const paymentIndex = pathParts.indexOf('payment');

        if (paymentIndex !== -1 && paymentIndex < pathParts.length - 1) {
          const potentialId = pathParts[paymentIndex + 1];
          // Check if it looks like a UUID
          if (potentialId && potentialId !== 'index' && /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(potentialId)) {
            const newUrl = `/wilczy-polmaraton/payment/?id=${potentialId}`;
            window.location.href = newUrl;
            return true;
          }
        }
        return false;
      }

      function renderPaymentWidget(transactionID: string, formContext: string, totalAmount: number) {
        // Load SIBS SPG widget script
        const script = document.createElement('script');
        script.src = `https://api.sibsgateway.com/assets/js/widget.js?id=${transactionID}`;
        script.onload = function() {
          const container = document.getElementById('payment-form-container');
          if (!container) return;
          container.style.display = 'block';

          // Create the SPG payment form
          const form = document.createElement('form');
          form.className = 'paymentSPG';
          form.setAttribute('spg-context', formContext);
          // SIBS SPG expects amount in major currency units (e.g. 100 for 100 PLN, NOT 10000 groszy)
          form.setAttribute('spg-config', JSON.stringify({
            paymentMethodList: ['BLIK', 'PAY_BY_LINK', 'CARD'],
            amount: {
              value: totalAmount,
              currency: 'PLN'
            },
            language: 'pl',
            redirectUrl: 'https://www.zatyrani.pl/wilczy-polmaraton/panel?payment=success'
          }));

          container.appendChild(form);
        };
        script.onerror = function() {
          const title = document.getElementById('title');
          const message = document.getElementById('message');
          const errorMessage = document.getElementById('error-message');
          const panelLink = document.getElementById('panel-link');
          if (title) title.textContent = 'Błąd ładowania';
          if (message) message.style.display = 'none';
          if (errorMessage) {
            errorMessage.innerHTML = 'Nie udało się załadować formularza płatności. Spróbuj odświeżyć stronę lub skontaktuj się z organizatorem: <a href="mailto:biuro@zatyrani.pl">biuro@zatyrani.pl</a>';
            errorMessage.style.display = 'block';
          }
          if (panelLink) panelLink.style.display = 'inline-block';
        };
        document.head.appendChild(script);
      }

      async function handlePayment() {
        if (handleLegacyUrl()) {
          return;
        }

        const urlParams = new URLSearchParams(window.location.search);
        let paymentId = urlParams.get('id');

        if (!paymentId) {
          const pathParts = window.location.pathname.split('/');
          const lastPart = pathParts[pathParts.length - 1];
          if (lastPart && lastPart !== 'payment' && lastPart !== '') {
            paymentId = lastPart;
          }
        }

        if (!paymentId) {
          window.location.href = '/wilczy-polmaraton/panel';
          return;
        }

        try {
          const response = await fetch(`/api/events/wilczypolmaraton-2026/payment/${paymentId}`);
          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || 'Failed to load payment details');
          }

          if (!data.has_pending_payment) {
            const title = document.getElementById('title');
            const message = document.getElementById('message');
            const spinner = document.getElementById('spinner');
            const infoMessage = document.getElementById('info-message');
            const panelLink = document.getElementById('panel-link');
            if (title) title.textContent = 'Brak nieopłaconych płatności';
            if (message) message.textContent = data.message || 'Wszystkie płatności zostały już zrealizowane.';
            if (spinner) spinner.style.display = 'none';
            if (infoMessage) {
              infoMessage.textContent = 'Możesz przejść do panelu, aby zobaczyć szczegóły rejestracji.';
              infoMessage.style.display = 'block';
            }
            if (panelLink) panelLink.style.display = 'inline-block';
            return;
          }

          if (data.payment && data.payment.formContext && data.payment.transactionID) {
            const spinner = document.getElementById('spinner');
            const message = document.getElementById('message');
            const title = document.getElementById('title');
            const blikNotice = document.getElementById('blik-notice');
            const transferTitle = document.getElementById('transfer-title');
            const transferNotice = document.getElementById('transfer-notice');
            if (spinner) spinner.style.display = 'none';
            if (message) message.style.display = 'none';
            if (title) title.textContent = 'Płatność - Wilczy Półmaraton 2026';
            if (blikNotice) blikNotice.style.display = 'block';
            if (transferTitle) transferTitle.textContent = (data.payment.contact_person || '') + ' Wilczy Polmaraton';
            if (transferNotice) transferNotice.style.display = 'block';
            renderPaymentWidget(data.payment.transactionID, data.payment.formContext, data.payment.total_amount);
          } else {
            throw new Error('Brak danych formularza płatności');
          }
        } catch (error) {
          console.error('Payment error:', error);
          const title = document.getElementById('title');
          const message = document.getElementById('message');
          const errorMessage = document.getElementById('error-message');
          const spinner = document.getElementById('spinner');
          const panelLink = document.getElementById('panel-link');
          if (title) title.textContent = 'Błąd płatności';
          if (message) message.style.display = 'none';
          if (errorMessage) {
            errorMessage.innerHTML = 'Wystąpił błąd podczas tworzenia płatności. Spróbuj ponownie lub skontaktuj się z organizatorem: <a href="mailto:biuro@zatyrani.pl">biuro@zatyrani.pl</a>';
            errorMessage.style.display = 'block';
          }
          if (spinner) spinner.style.display = 'none';
          if (panelLink) panelLink.style.display = 'inline-block';
        }
      }

      handlePayment();
    </script>
  </body>
</html>
