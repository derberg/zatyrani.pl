---
import Layout from "../../../layouts/Layout.astro";
import WilczyPolmaratonHeader from "../../../components/wilczypolmaraton/WilczyPolmaratonHeader.astro";
import { t } from "../../../utils/i18n";

const eventDate = "07.08.2026";
// Registration closes at the end of this day. Mirrors zewwilka-2026.registrationDeadline
// in api/events/config.js — the server enforces it; this only drives the UI.
const registrationDeadline = "2026-08-05";

const facts = [
  { label: "Nazwa", value: "Nocny Zew Wilka (bieg nocny ~10 km)" },
  { label: "Kiedy", value: "7 sierpnia 2026, godz. 20:00" },
  { label: "Start i meta", value: "Azyl Zatyranych 🌲" },
  { label: "Dystans", value: "ok. 10 km" },
  { label: "Wstęp", value: "Bezpłatny — obowiązkowa rejestracja" },
  { label: "Limit miejsc", value: "Tylko 50 osób ⚠️" },
];

const sections = [
  {
    icon: "🚗",
    title: "Logistyka i parking",
    body: "Wszystkich zmotoryzowanych prosimy o pozostawienie aut na parkingu przy cmentarzu w Rybniku-Ochojcu (ul. Milenijna). Stamtąd sprawnie i bezpiecznie dotrzecie do Azylu na start.",
  },
  {
    icon: "🗺️",
    title: "Dzika trasa — przygoda z trackiem",
    body: "To nie będzie zwykły bieg z taśmami i strzałkami. Wracamy do korzeni i prawdziwego trailu — trasa NIE będzie oznaczona. Biegniemy na podstawie wgranego tracka GPS (plik GPX udostępnimy przed biegiem). Czołówki i naładowane zegarki/telefony z GPS to wyposażenie obowiązkowe! 🔦",
  },
  {
    icon: "⏱️",
    title: "Profesjonalizm i integracja",
    body: "Mimo luźnej, treningowej atmosfery nie zabraknie sportowej rywalizacji — zapewniamy profesjonalny pomiar czasu, więc sprawdzicie formę przed październikowym startem. A po biegu prawdziwa wilcza uczta: ognisko, pyszny poczęstunek i biegowe pogaduchy.",
  },
  {
    icon: "📝",
    title: "Jak dołączyć? Kto pierwszy, ten lepszy!",
    body: "Wstęp jest darmowy, ale ze względów bezpieczeństwa i kameralnego charakteru przygotowaliśmy zaledwie 50 miejsc. Nie zwlekajcie — miejsca w stadzie rozejdą się błyskawicznie.",
  },
];
---

<Layout
  title="Nocny Zew Wilka - bieg nocny 10 km"
  description="Nocny Zew Wilka — darmowy bieg nocny ~10 km, oficjalna rozgrzewka przed IV Wilczym Półmaratonem. 7 sierpnia 2026, godz. 20:00, Azyl Zatyranych (Rybnik-Ochojec)."
  ogImage="/wilczypolmaraton_og.jpg"
  t={t}
>
  <WilczyPolmaratonHeader t={t} />

  <!-- Hero -->
  <div class="bg-gradient-to-br from-slate-900 via-slate-800 to-emerald-900 text-white">
    <div class="mx-auto max-w-3xl px-6 py-16 text-center space-y-6">
      <p class="text-sm font-semibold uppercase tracking-widest text-emerald-300">🐺 Oficjalna rozgrzewka przed IV Wilczym Półmaratonem</p>
      <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">Nocny Zew Wilka</h1>
      <p class="text-2xl font-semibold text-emerald-300">{eventDate} · 20:00</p>
      <p class="text-lg text-slate-200">📍 Azyl Zatyranych, Rybnik-Ochojec</p>

      <div class="flex flex-wrap justify-center gap-3 text-base">
        <span class="rounded-full bg-white/10 px-4 py-2 ring-1 ring-white/20 backdrop-blur-sm">🌙 bieg nocny ~10 km</span>
        <span class="rounded-full bg-white/10 px-4 py-2 ring-1 ring-white/20 backdrop-blur-sm">🆓 bezpłatny</span>
        <span class="rounded-full bg-white/10 px-4 py-2 ring-1 ring-white/20 backdrop-blur-sm">⚠️ tylko 50 miejsc</span>
      </div>

      <!-- Registration CTA (swapped to a "closed" notice after the deadline) -->
      <div class="pt-4" data-deadline={registrationDeadline}>
        <div id="registerCta">
          <a
            href="/wilczy-polmaraton/zewwilka/rejestracja"
            class="inline-block rounded-full bg-emerald-500 px-8 py-3 text-lg font-semibold text-white transition hover:bg-emerald-400"
          >
            Zapisz się
          </a>
          <p class="mt-3 text-sm text-slate-300">Zapisy bezpłatne, do 5 sierpnia 2026</p>
        </div>
        <div id="registerClosed" class="hidden">
          <span class="inline-block rounded-full bg-white/10 px-8 py-3 text-lg font-semibold text-slate-300 ring-1 ring-white/20">
            Zapisy zamknięte
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Intro -->
  <div class="mx-auto max-w-2xl px-6 pt-16">
    <p class="text-lg leading-relaxed text-slate-700">
      Słyszycie ten zew? Październikowy <strong>IV Wilczy Półmaraton</strong> zbliża się wielkimi krokami — ale my nie
      zamierzamy czekać w ukryciu. Zanim leśne ścieżki uroczyska „Głębokie Doły" zapełnią się setkami biegaczy w blasku
      jesiennego słońca, zapraszamy na wyjątkowy, mroczny prolog. Już 7 sierpnia o 20:00 wbiegniemy w głąb lasu, by
      poczuć prawdziwie wilczy klimat pod osłoną nocy! 🌲🌕
    </p>
  </div>

  <!-- Facts -->
  <div class="mx-auto max-w-2xl px-6 pt-10">
    <div class="rounded-2xl border-2 border-emerald-200 bg-emerald-50 p-6">
      <h2 class="mb-4 text-lg font-bold text-slate-900">ℹ️ Szczegóły wydarzenia</h2>
      <dl class="space-y-2">
        {facts.map(({ label, value }) => (
          <div class="flex flex-col gap-0.5 sm:flex-row sm:gap-3">
            <dt class="w-32 shrink-0 font-semibold text-slate-700">{label}:</dt>
            <dd class="text-slate-800">{value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- Detail sections -->
  <div class="mx-auto max-w-2xl space-y-6 px-6 py-12">
    {sections.map(({ icon, title, body }) => (
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="flex items-center gap-3 text-xl font-bold text-slate-900">
          <span aria-hidden="true">{icon}</span>{title}
        </h2>
        <p class="mt-2 leading-relaxed text-slate-700">{body}</p>
      </div>
    ))}

    <p class="text-center text-lg font-semibold text-slate-800">
      Poczuj zew przygody, sprawdź formę w nocy i stań się częścią wilczego stada jeszcze tego lata.
      Do zobaczenia w Azylu Zatyranych! 🐺🔥
    </p>

    <div class="text-center" data-deadline={registrationDeadline}>
      <a
        id="registerCtaBottom"
        href="/wilczy-polmaraton/zewwilka/rejestracja"
        class="inline-block rounded-full bg-emerald-600 px-8 py-3 text-lg font-semibold text-white transition hover:bg-emerald-700"
      >
        Zapisz się
      </a>
    </div>
  </div>

  <script>
    // Show "Zapisy zamknięte" once the deadline day has fully passed.
    const wrapper = document.querySelector("[data-deadline]");
    const deadline = wrapper?.getAttribute("data-deadline");
    if (deadline) {
      const end = new Date(deadline);
      end.setHours(23, 59, 59, 999);
      if (new Date() > end) {
        document.getElementById("registerCta")?.classList.add("hidden");
        document.getElementById("registerClosed")?.classList.remove("hidden");
        document.getElementById("registerCtaBottom")?.remove();
      }
    }
  </script>
</Layout>
