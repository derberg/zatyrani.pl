---
import Layout from "../../layouts/Layout.astro";
import NieboCrossHeader from "../../components/niebocross/NieboCrossHeader.astro";
import { t } from "../../utils/i18n";
---

<Layout
  title="Koszulka pamiątkowa - NieboCross 2026"
  description="Zamów pamiątkową koszulkę sportową z charytatywnego biegu NieboCross 2026"
  ogImage="/niebocross_og.jpg"
  t={t}
>
  <NieboCrossHeader t={t} />

  <section class="bg-gradient-to-b from-slate-50 to-white py-10 px-4">
    <div class="mx-auto max-w-3xl">

      <!-- Title -->
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">Koszulka pamiątkowa</h2>
        <p class="mt-2 text-lg text-slate-600">Sportowa koszulka z dedykowanym wzorem NieboCross 2026</p>
      </div>

      <!-- T-shirt images -->
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <img src="/niebocross/tshirt-front.png" alt="Koszulka NieboCross - przód" class="w-full max-w-xs rounded-2xl border border-slate-200 shadow-lg" />
        <img src="/niebocross/tshirt-back.png" alt="Koszulka NieboCross - tył" class="w-full max-w-xs rounded-2xl border border-slate-200 shadow-lg" />
      </div>

      <!-- Explanation (only shown for registered participants) -->
      <div id="registration-explanation" class="hidden rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-5 mb-6 text-sm leading-relaxed text-slate-700">
        Podczas rejestracji zbieraliśmy informację o rozmiarze koszulki, jednak nie udało nam się pozyskać odpowiednich środków od partnerów, aby rozdać koszulki za darmo.
        Dlatego oferujemy możliwość zakupu koszulki pamiątkowej po kosztach produkcji.
      </div>

      <!-- Cost info -->
      <div class="rounded-2xl bg-amber-50 ring-1 ring-amber-200 p-5 mb-6 text-sm leading-relaxed text-amber-900">
        <p class="font-semibold mb-1">60 zł — koszt produkcji koszulki</p>
        Cała kwota pokrywa wyłącznie koszt wyprodukowania koszulki.
        Żadne pieniądze nie trafiają do organizatora ani na cele charytatywne — to czysta cena produkcji.
      </div>

      <!-- Price -->
      <p class="text-center text-4xl font-black text-emerald-600 mb-8">60 zł</p>

      <!-- Card with form -->
      <div class="rounded-2xl bg-white ring-1 ring-slate-200 shadow-xl p-6 sm:p-8">

        <!-- Loading state -->
        <div id="loading-state" class="text-center py-8">
          <div class="inline-block h-10 w-10 animate-spin rounded-full border-4 border-slate-200 border-t-emerald-500"></div>
          <p class="mt-4 text-slate-600">Ładowanie danych...</p>
        </div>

        <!-- Participant greeting (shown when accessed via SMS link) -->
        <div id="participant-greeting" class="hidden mb-5 rounded-xl bg-sky-50 ring-1 ring-sky-200 p-4 text-sm text-sky-800 leading-relaxed"></div>

        <!-- Order form -->
        <form id="order-form" class="hidden space-y-5">
          <input type="hidden" id="participantId" name="participantId" value="" />

          <div>
            <label for="firstName" class="block text-sm font-semibold text-slate-700 mb-1">Imię <span class="text-red-500">*</span></label>
            <input type="text" id="firstName" name="firstName" required
              class="block w-full rounded-lg border-2 border-emerald-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 px-3 py-2" />
          </div>

          <div>
            <label for="lastName" class="block text-sm font-semibold text-slate-700 mb-1">Nazwisko <span class="text-red-500">*</span></label>
            <input type="text" id="lastName" name="lastName" required
              class="block w-full rounded-lg border-2 border-emerald-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 px-3 py-2" />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input type="email" id="email" name="email" required
              class="block w-full rounded-lg border-2 border-emerald-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 px-3 py-2" />
          </div>

          <div>
            <label for="phoneNumber" class="block text-sm font-semibold text-slate-700 mb-1">Numer telefonu <span class="text-red-500">*</span></label>
            <input type="tel" id="phoneNumber" name="phoneNumber" required
              class="block w-full rounded-lg border-2 border-emerald-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 px-3 py-2" />
          </div>

          <div>
            <label for="tshirtSize" class="block text-sm font-semibold text-slate-700 mb-1">Podaj prawidłowy rozmiar koszulki <span class="text-red-500">*</span></label>
            <select id="tshirtSize" name="tshirtSize" required
              class="block w-full rounded-lg border-2 border-emerald-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 px-3 py-2">
              <option value="">— wybierz rozmiar —</option>
              <optgroup label="Dziecięce">
                <option value="116">116</option>
                <option value="128">128</option>
                <option value="134">134</option>
                <option value="140">140</option>
                <option value="146">146</option>
                <option value="152">152</option>
              </optgroup>
              <optgroup label="Dorosłe">
                <option value="XS">XS</option>
                <option value="S">S</option>
                <option value="M">M</option>
                <option value="L">L</option>
                <option value="XL">XL</option>
                <option value="XXL">XXL</option>
              </optgroup>
            </select>
          </div>

          <div>
            <label class="flex items-start gap-2 cursor-pointer">
              <input type="checkbox" id="pickupConsent" required
                class="mt-1 rounded border-emerald-300 border-2 text-emerald-600 focus:ring-emerald-500" />
              <span class="text-sm text-slate-700">Oświadczam, że wiem, iż koszulkę będzie można odebrać wyłącznie w biurze zawodów w dniu wydarzenia, 12 kwietnia. <span class="text-red-500">*</span></span>
            </label>
          </div>

          <button type="submit" id="buy-btn"
            class="w-full rounded-full bg-emerald-500 px-6 py-3 text-base font-semibold text-slate-900 shadow-lg shadow-emerald-500/30 transition hover:-translate-y-0.5 hover:bg-emerald-400 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0">
            Zamów koszulkę
          </button>
        </form>

        <!-- Payment widget container -->
        <div id="payment-form-container" class="hidden mt-4 min-h-[400px]"></div>

        <!-- Messages -->
        <div id="error-message" class="hidden mt-4 rounded-xl bg-red-50 ring-1 ring-red-200 p-4 text-sm text-red-700"></div>
        <div id="success-message" class="hidden mt-4 rounded-xl bg-emerald-50 ring-1 ring-emerald-200 p-6 text-center text-emerald-800"></div>
      </div>

      <!-- Contact info -->
      <div class="mt-6 text-center text-sm text-slate-500 leading-relaxed">
        <p>Pytania? Problemy z zamówieniem? Skontaktuj się z nami:</p>
        <p class="mt-1 font-semibold text-slate-700">
          <a href="tel:+48784640977" class="hover:text-emerald-600">784 640 977</a>
          &nbsp;·&nbsp;
          <a href="mailto:biuro@zatyrani.pl" class="hover:text-emerald-600">biuro@zatyrani.pl</a>
        </p>
      </div>

    </div>
  </section>
</Layout>

<script>
  const API_BASE = '/api/niebocross/tshirt/purchase';

  function showError(msg) {
    const el = document.getElementById('error-message');
    el.innerHTML = msg;
    el.classList.remove('hidden');
  }

  function hideError() {
    document.getElementById('error-message').classList.add('hidden');
  }

  function renderPaymentWidget(transactionID, formContext) {
    document.getElementById('order-form').classList.add('hidden');
    const container = document.getElementById('payment-form-container');
    container.classList.remove('hidden');

    const script = document.createElement('script');
    script.src = `https://api.sibsgateway.com/assets/js/widget.js?id=${transactionID}`;
    script.onload = function () {
      const form = document.createElement('form');
      form.className = 'paymentSPG';
      form.setAttribute('spg-context', formContext);
      form.setAttribute('spg-config', JSON.stringify({
        paymentMethodList: ['CARD', 'BLIK'],
        amount: { value: 6000, currency: 'PLN' },
        language: 'pl',
        redirectUrl: 'https://zatyrani.pl/niebocross/koszulka?status=success'
      }));
      container.appendChild(form);
    };
    script.onerror = function () {
      showError('Nie udało się załadować formularza płatności. Spróbuj odświeżyć stronę lub napisz: <a href="mailto:biuro@zatyrani.pl" class="underline font-semibold">biuro@zatyrani.pl</a>');
    };
    document.head.appendChild(script);
  }

  async function init() {
    const params = new URLSearchParams(window.location.search);

    // If returning from successful payment
    if (params.get('status') === 'success') {
      document.getElementById('loading-state').classList.add('hidden');
      const el = document.getElementById('success-message');
      el.innerHTML = '<p class="text-lg font-bold mb-1">Dziękujemy za zamówienie!</p><p>Płatność została przyjęta. Koszulkę otrzymasz w dniu wydarzenia.</p>';
      el.classList.remove('hidden');
      return;
    }

    const participantId = params.get('id');

    if (participantId) {
      try {
        const resp = await fetch(`${API_BASE}?participantId=${participantId}`);
        const data = await resp.json();

        if (data.success && data.participant) {
          const p = data.participant;

          // Already ordered — show message, hide form
          if (data.alreadyOrdered) {
            document.getElementById('loading-state').classList.add('hidden');
            const el = document.getElementById('success-message');
            el.innerHTML =
              `<p class="text-lg font-bold mb-1">Cześć ${p.firstName}!</p>` +
              `<p>Koszulka w rozmiarze <strong>${data.orderedSize}</strong> została już zamówiona i opłacona. Otrzymasz ją w dniu wydarzenia.</p>`;
            el.classList.remove('hidden');
            return;
          }

          document.getElementById('participantId').value = p.id;
          document.getElementById('firstName').value = p.firstName || '';
          document.getElementById('lastName').value = p.lastName || '';
          document.getElementById('email').value = p.email || '';
          document.getElementById('phoneNumber').value = p.phoneNumber || '';
          if (p.tshirtSize) {
            document.getElementById('tshirtSize').value = p.tshirtSize;
          }

          // Show registration explanation
          document.getElementById('registration-explanation').classList.remove('hidden');

          // Lock name fields for known participants
          document.getElementById('firstName').readOnly = true;
          document.getElementById('lastName').readOnly = true;
          document.getElementById('firstName').classList.add('bg-slate-100', 'text-slate-500', 'cursor-not-allowed');
          document.getElementById('lastName').classList.add('bg-slate-100', 'text-slate-500', 'cursor-not-allowed');

          // Show greeting
          const greeting = document.getElementById('participant-greeting');
          greeting.innerHTML =
            `<p class="font-semibold mb-1">Cześć ${p.firstName}! Zamawiasz koszulkę dla siebie.</p>` +
            `<p>Jeśli zarejestrowałeś/aś więcej osób na ten sam numer telefonu, dostaniesz kilka SMS-a z osobnym linkiem do zamówienia koszulki dla każdego z osobna.</p>`;
          greeting.classList.remove('hidden');
        }
      } catch (err) {
        console.error('Error fetching participant:', err);
      }
    }

    document.getElementById('loading-state').classList.add('hidden');
    document.getElementById('order-form').classList.remove('hidden');
  }

  document.getElementById('order-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    hideError();

    const btn = document.getElementById('buy-btn');
    btn.disabled = true;
    btn.textContent = 'Przetwarzanie...';

    const body = {
      participantId: document.getElementById('participantId').value || null,
      firstName: document.getElementById('firstName').value.trim(),
      lastName: document.getElementById('lastName').value.trim(),
      email: document.getElementById('email').value.trim(),
      phoneNumber: document.getElementById('phoneNumber').value.trim(),
      tshirtSize: document.getElementById('tshirtSize').value,
    };

    try {
      const resp = await fetch(API_BASE, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await resp.json();

      if (!resp.ok || !data.success) {
        throw new Error(data.error || 'Błąd podczas tworzenia zamówienia');
      }

      renderPaymentWidget(data.payment.transactionID, data.payment.formContext);
    } catch (err) {
      console.error('Purchase error:', err);
      showError(err.message || 'Wystąpił błąd. Spróbuj ponownie lub napisz: <a href="mailto:biuro@zatyrani.pl" class="underline font-semibold">biuro@zatyrani.pl</a>');
      btn.disabled = false;
      btn.textContent = 'Zamów koszulkę';
    }
  });

  init();
</script>
