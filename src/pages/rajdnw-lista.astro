---
import Layout from "../layouts/Layout.astro";
import { t } from "../utils/i18n";

const eventDate = "23.05.2026";
const eventNumber = "IV";
const maxParticipants = 55;
---

<Layout t={t} title="Zatyrani - IV Rajd Nordic Walking">
  <!-- Hero Section -->
  <div class="relative h-[calc(85vh-40px)] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="rajdnw/2025/header-brighter.webp" alt="Tło rajdu" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/20"></div>
    </div>
    <div class="relative text-center space-y-4 -translate-y-5">
      <div class="px-8 rounded-lg mx-auto max-w-full">
        <h1 class="text-5xl font-bold text-gray-600">{eventNumber} Rajd Nordic Walking</h1>
      </div>

      <div class="pt-1 lg:pt-0 rounded-lg mx-auto inline-block">
        <h1 class="text-3xl font-bold text-gray-600">{eventDate}</h1>
        <p class="text-xl text-gray-600 text-center mt-2">"Młynówka" ul. Smolnicka 4, Leboszowice</p>
      </div>
    </div>
  </div>

  <section class="mt-16">
    <h2 id="zapisy" class="text-3xl font-bold text-center">Lista Startowa</h2>
    <p class="text-center text-lg mt-2">Zapisanych: <span id="registeredCount">...</span> / {maxParticipants}</p>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <hr class="my-4 border-t border-gray-300" />

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="w-full">
          <thead class="bg-green-200/70 text-green-900">
            <tr>
              <th class="px-4 py-3 text-left text-sm font-semibold">#</th>
              <th class="px-4 py-3 text-left text-sm font-semibold">Nazwisko i Imię</th>
              <th class="px-4 py-3 text-left text-sm font-semibold">Miejscowość</th>
              <th class="px-4 py-3 text-left text-sm font-semibold">Klub</th>
            </tr>
          </thead>
          <tbody id="participantsTableBody" class="divide-y divide-gray-200">
            <tr><td colspan="4" class="px-4 py-6 text-center text-gray-500">Ładowanie...</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div id="participantsCards" class="md:hidden flex flex-col gap-3"></div>
    </div>
  </section>

  <script>
    async function loadParticipants() {
      const tbody = document.getElementById("participantsTableBody");
      const cards = document.getElementById("participantsCards");
      const countEl = document.getElementById("registeredCount");
      try {
        const res = await fetch("/api/nwrajd-participants");
        const participants = await res.json();
        countEl.textContent = participants.length;
        if (participants.length === 0) {
          tbody.innerHTML = `<tr><td colspan="4" class="px-4 py-6 text-center text-gray-500">Brak zapisanych uczestników.</td></tr>`;
          cards.innerHTML = `<p class="text-center text-gray-500 py-6">Brak zapisanych uczestników.</p>`;
          return;
        }
        tbody.innerHTML = participants.map((p, i) => `
          <tr class="hover:bg-green-50 transition">
            <td class="px-4 py-3 text-sm text-gray-500">${i + 1}</td>
            <td class="px-4 py-3 text-sm text-gray-900">${p.lastname} ${p.firstname}</td>
            <td class="px-4 py-3 text-sm text-gray-600">${p.location}</td>
            <td class="px-4 py-3 text-sm text-gray-600">${p.club || "–"}</td>
          </tr>
        `).join("");
        cards.innerHTML = participants.map((p, i) => `
          <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-gray-900">${p.lastname} ${p.firstname}</p>
                <p class="text-sm text-gray-500 mt-0.5">${p.location}${p.club ? ' · ' + p.club : ''}</p>
              </div>
              <span class="flex-shrink-0 text-xs text-gray-400">${i + 1}</span>
            </div>
          </div>
        `).join("");
      } catch {
        tbody.innerHTML = `<tr><td colspan="4" class="px-4 py-6 text-center text-red-500">Błąd ładowania listy.</td></tr>`;
        cards.innerHTML = `<p class="text-center text-red-500 py-6">Błąd ładowania listy.</p>`;
        countEl.textContent = "?";
      }
    }
    loadParticipants();
  </script>
</Layout>
