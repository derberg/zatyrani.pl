---
import Layout from "../../../layouts/Layout.astro";
import PanelContent from "../../../components/wilczypolmaraton/PanelContent.astro";
import { t as tBase } from "../../../utils/i18n";

const t = (key: string) => tBase(key, 'en');
---

<Layout
  title={`Wilczy Półmaraton 2026 - ${t("wilczypolmaraton.dashboard.title")}`}
  description={t("wilczypolmaraton.dashboard.meta_description")}
  ogImage="/wilczypolmaraton_og.jpg"
  t={t}
>
  <PanelContent t={t} locale="en" />
</Layout>
